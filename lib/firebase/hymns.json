[
  {
    "sr": "ZS0021",
    "title": "MOONAM SWARGATHIL",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2021.0",
    "page": "0021",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nमून्नाम स्वर्गन्तिल \nवाणीस्न्न ज्ञानमे - स्वर्ग राज्ञीये\nइन्न ई सीयोनिल \nमक्कळतन कूडे वस्सीक्यूवान - वन्न ज्ञानमे\n\nन्यान अँए आराधिक्युन्नू \nन्यान अँए महत्वपेडुत्तुन्न् \nज्ञानमे देव राज्ञीये\n\nCH\nआराधिक्यून् न्यान, स्नेहिच्चीडुन्नू \nएन्डे ज्ञानमे, राज्ञीये परिशुध्दये\n\nVerse 1\nमनुष्य पूत्ररिल आनंदिच्चीडूवान\nस्वर्गत्तिल निन्नुम एन्ने तेडी वन्नू\nइडरूमेन वळीगळिल कूटागणे\nएन्डे अम्मे दैव ज्ञानमे\n\nVerse 2\nज्ञान भवनत्तिल निन्नुम एन्ने काणुम\nएन्ने नंन्नाई अरीयुम एन्न दैवमे\nओरु नोकु काणूवान कारिक्यून्न्\nएन्डे अम्मे दैव ज्ञानमे"
    }
  },
  {
    "sr": "ZS0022",
    "title": "DAIVAKRUPAYUDE RAJNIYE",
    "Key": "",
    "Dedicated": "AMMA",
    "year": "2021.0",
    "page": "0022",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "\nIntro\nदैव कृब राज्ञीये\nअनष्वरयाम एन्डे अम्मे\nकूलीनयाय सीयोनिल वाळुम\nअवीकल सौन्दर्यमे\n\nइस्राएलिन अम्मयाय\nमक्कळतन आनंदमाय\nदैव कृबयाले एन्नुम\nएन्ने ताञुम स्नेहमे\n\nCh\nएन्डे अम्मे आराधना\nदैव ज्ञानमे एल राज्ञीये\nएन्डे अम्मे आराधना\nदैव मक्कळतन आश्रयमे\n\nVerse 1\nएनिक्य एरे कूरवूगळ उन्डेंगीलुम\nअम्मतन स्नेहम एन्ने तीरिन्यदिल्ला\nएनिले नन्मगळ कन्डीट्टिन्नुम\nनेन्जोडू चेतन अम्मयेल्ले\nअम्मे न्यान उन्नुम अँए पैदलाय\nतीस मुन्बिल वळत्नीडान कृबयगणे\n\nVerse 2\nएन्न अम्मा पो.. गुम इडम उल्लाम\nअम्मतन कूडे कुडे न्यौनुम वन्नीडुम\nजानमाम उन्न अम्मा वस्सीक्युन्नीडम\nअम्मतन कूडे यानुम वस्सीच्चीडुम\nआओ स्नेह तणलिन कूडारत्तिल\nवस्सीक्यान एन्नुम अम्मे कृबयेगणे\n"
    }
  },
  {
    "sr": "ZS0023",
    "title": "YUDHAVAMSHATIN SIMHAM",
    "Key": "",
    "Dedicated": "SAR",
    "year": "2021.0",
    "page": "0023",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nयूदा वमशत्तिन सिम्हम\nदावीदिन्ड वेरे\nअवन विजयम वरिच्चीरिक्युन्नू\nपुस्तग चूरूळ निवर्तूवान\nसप्त मूद्रगळ तूरक्कूवान\nअवन एन्नुम योग्यन\n\nCh\nविजयम वरिच्चवन ... एन नीधी\nदावीदिन्उडे वेरे ... एन नीथी\nउडम्बडी दूदन ... एन नीथी\nएशेय्या प्रवाजगन\n\nमरणत्ते जयीच्चवन\nतीरीगे वन्नीदा\n\nसीयोन देशत्तिल यूदा वमशत्तिल\nउयरून्निदा सिम्ह गर्जनम\nसीयोन देशत्तिल यूदा वमशत्तिल\nउदिच्चूयर्तीडुम नीधी सूर्यन अवन\n\nVerse 1\nदेवत्तिन स्वरमाय अवन\nनित्य जीवनू साक्ष्यम तन्न अवन\nमरणत्तिनमेल विजयम वरिच्च\nसीयोन्नीडे नीधीयायवन\nदैव नीधीतन कूडारत्तिल\nआनंदत्तिन घोशम उयरुन्नू\nज्ञानमाम अम्मयोडू चेर्न\nउद्‌घोषिक्युन्निदा\n\nVerse 2\nसीयोनिन जीवनाधनाम\nनक्युम जीविक्युन्नवन\nमलमूगळिल उयरुम स्वरम अवन\nइम्मानुएलिन्डे उयरुम स्वरम अवन\nदैव नीधीतन कूडारत्तिल\nआनंदत्तिन घोशम उयरुन्नू\nज्ञानमाम अम्मयोडू चेर्न\nउद्‌घोषिक्युन्निदा\n"
    }
  },
  {
    "sr": "ZS0024",
    "title": "EL YASHEEV EL HAMEITEEV MAL",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0024",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nएल... याषीव एल... एल हमेय्तीव (4)\n\nअत्युन्नदन मक्कळकेल्लाम\nनन्मयक्याय माटीडुन्नू\nसर्व शक्तन सघलतेयुम\nपुन : स्थापिच्चीडुन्नू\n\nCH\nस्वर्गतोळम सीयोने\nउयर्तीडुम अत्युन्नदने\n\nस्वर्गम मूळूवन आराधिक्युन्नू\nसीयोन ओन्नाइ उद्‌घोशिक्युन्न\nएल याषीव एल एल हमेय्तीव\n\nVerse 1\nअडीमत्तत्तिन नुगंगळ तगरकुम\nझीर्णदये ग्रस्सीच्चीडुम \nमरतिनमेल विजय वरिक्युम\nदैवत्तिन पद्धदी\n\nVerse 2\nशुभमाम भावीयुम प्रत्याशयुम\nनलगीडुम पद्‌द्यदीयाल\nइस्त्राएलिन ऐश्वर्यम\nपुन : स्थापिच्चीडुम दैवमे\n\n"
    }
  },
  {
    "sr": "ZS0025",
    "title": "EL YASHEEV EL HAMEITEEV ENG",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0025",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nEL EL YASHEEV EL EL HAMEITEEV\n\nMY FATHER HAS A PLAN FOR ME \nOF A BEAUTIFUL FUTURE N HOPE\nRESTORING ALL THE PROSPERITY\nOF GOD'S OWN ZION\n\nCH\nTHE MOST HIGH GOD THE FATHER TURNS ALL\nTHINGS FOR THE GOOD OF HIS CHILDREN\n\nEL EL YASHEEV EL EL HAMEITEEV\n\nGOD THE FATHER RESTORES THE RUINS\nOF THE GENERATIONS THE FORTUNE OF ZION\nGATHERING US FROM THE NATIONS\n\nVerse 1\nNEITHER DEATH NOR LIFE NOR EVIL POWERS\nHEIGHT NOR DEPTH NOR ANYTHING ELSE\nCAN EVER SEPARATE US - ZION\nFROM THE LOVE OF GOD IN EMMANUEL\n\nTHE MOST HIGH GOD THE FATHER TURNS ALL\nTHINGS FOR THE GOOD OF HIS CHILDREN\n\nEL EL YASHEEV EL EL HAMEITEEV"
    }
  },
  {
    "sr": "ZS0026",
    "title": "ELLATILUM",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0026",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "Intro\nसबसे ऊँचा \nएक‌मात्र नाम है \nसारे घुटने झुकाए वो नाम है \nहर जुबान गाएं \nएल येशू नाम \nसब भलाई में बदले वो नाम है\n\nCH 1\nअद्भूत है येशू नाम \nअतिशय है येशू नाम \nआश्चर्यपूर्ण येशू नाम \nअधिकारपूर्ण येशू नाम \n\nलाखों में आप ही सुंदर है \nसीयोन के राजा है\nआपके समान अप्पा आप ही हो\n\nVerse 1\nस्वर्ग तक सीयोन को\nउठाता वो नाम \nस्वर्ग सारा आराधित कर वो नाम \nमृत्यु पर विजयी बनाता वो नाम \nसर्व पुनः स्थापित करता वो नाम\n\nCH 2\nअनुग्रह है येशू नाम \nविजयी बनाता येशू नाम \nमुद्रित हैं येशू नाम \nसंरक्षण देता येशू नाम\n",
      "Malayalam": "Intro\nएल्लाटीलुम मेलाय\nओरेओरू नामंम\nएल्ला मूळंगालुम मडंञीडुम नामंम\nएल्ला नावूम पाडुम एल येशू नामंम\nएल्लाम नन्मयक्याय माटुन्न नामंम\n\nCH\nअलभूदमाय नाममे अदीशयमाय नाममे\nआश्चर्यमाय नाममे अधीगारमुळ्ळ नाममे\nअनुग्रहमाय नाममे विजयम नलगुम नाममे\nमुद्रीदमाय नाममे समरक्षणमेगुम नाममे....\n\nपदीनाइरंगळिल सुन्दरने सीयोनिन राजावे\nअँएक्यू तूल्यनाय अँउ मात्रम\n"
    }
  },
  {
    "sr": "ZS0027",
    "title": "AGALATH MARYATH SNEHAM",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0027",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nअगलात मरयात्त स्नेहम\nपिदाविन अनष्वर स्नेहम\nएन हृदयव्यथंगळिल आष्वासमाय\nएन मनमुरुगीडुम्बोळ सान्तवनमाय स्नेहम\nओरुन्नाळुम पिरीयात्त स्नेहम\n\nCH\nयेशूवे एन दैवमे एन आश्रयम अँअल्लयो\nपरिशुद्धने परिपूर्णने अत्युन्नदने आराधना\nएन्डे अप्पा आराधना\nयेशू अप्पा आराधना\nएन्ने करूदी कातीडुन्न स्नेहमे\nएन्ने वळी नडत्तीडुन्न दैवमे\n\nVerse 1\nपाबचेट्टील न्यान अगप्पेट्ट वलन्यीडुम्बोळ\nसत्वार्तयाल अप्पन एन्ने वीन्डेडूत्तू\nस्वपूत्रने वीन्डुम अय्यच्चूवल्लो\nअवने अयच्चवने बलीयाय नलगी\nस्नेहमे प्राणने जीवने आराधना\n\nVerse 2\nई लोगत्तिल निन्न एन्ने वेरतीरीच्चु\nतन मक्कळोड कूडे एन्ने पारपिक्यूवान\nयेशू नाम्मत्तिल परीरेक्षयाल एन्ने\nओरो दिनवुम वळी नडत्तीडुम अप्पन\nस्नेहमे प्राणने जीवने आराधना\n"
    }
  },
  {
    "sr": "ZS0028",
    "title": "AZHAKINTE AZHAKAAM",
    "Key": "",
    "Dedicated": "AYYA",
    "year": "2022.0",
    "page": "0028",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "Intro\nओ सबसे सुंदर, मेरे प्राणधार\nसौंदर्य पूर्णता के पहलौटे\nपलक झपकाए बिना, इंतजार मैं करू\nमेरे अय्या आ जाओ\n\nCH\nओ रूपवान... इम्मानुएल\nराजाओं के राजा, अय्या\nप्राण मेरे, जीवन के जीवन\nआराधना मेरे अय्या\n\nआत्मनाथ की आराधना\nइम्मानुएल की आराधना\nचक्रवर्ती की आराधना... \nहालेलुया } (२)\n\nVerse 1\nसेब वृक्ष की छाया में, प्रभु मुझे\nछूकर उठाए, देखकर पसंद किया\nइस दाख की बारी में, जल्दी आइए\nमेरे नाथ को देखने तरसती हूँ\n\nVerse 2\nओ कन्याओं, \nमेरे प्रियतम को देखा क्या\nमेरे नाथ को देखा क्या, मेरे साथीयों\nइंतजार करू मैं, इस द्वार पर\nकदमों की आहट सुनने के लिए\n",
      "Malayalam": "Intro\nअळगिन्डे अळगा एन मणवाळने\nसौन्दर्यतिगविन अध्यजादने\nकणच्चिम्मादे न्यान कान्तीरिक्युन्निदा\nएन्डे अय्या वरणे\n\nCH\nअळगे इम्मानुएले राजाधीराजनाम अय्या\nप्राणने जीवन्डे जीवने आराधना एन्डे अय्या\nआत्मनाधने आराधना\nइम्मानुएले आराधना\nचक्रवर्तीये आराधना\nहालेलूया\n\nVerse 1\nआप्पिळ मरत्तिल चूवट्टील नाधन एन्ने\nतोट्टूणर्ती कन्डु इष्टमाय\nई मुन्दीत्तोपिल वेगम वरणे\nएन नाधने काणूवान कोदीयाय\n\nVerse 2\nकन्यगमोर एन प्रीयने कन्डूवो \nएन नाधने कन्डूवो तोळीमोर\nकात्तीरिक्युन्नू न्यान ई पडीवादिलिल\nकाल्लोच्चायोन्नु केटीड़ूवानाय\n"
    }
  },
  {
    "sr": "ZS0029",
    "title": "BHOOVIL VEENA VITHUPOL",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0029",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nसहनंगळ ती न्नाळमाय\nउळ्ळिन उळ्ळिल आळुम्बोळ\nयेन्न हदयत्तिन तेञळू‌गळिल\nन्यान नीधीये तेडुन्नू\n\nCH\nभूविल वीण वित्तूपोल\nतन्न जीवने एनिक्याय\nबलीयाइ नलगी एन्ने वीन्डेडुत्त\nएन्न नीधीये\n\nVerse 1\nइम्मानुए‌लिने वळी ओरुक्की\nमणवाटीयाय एन्ने ओरुक्कीडूवान\nतन्न जीवने एनिक्याय वेडिन्यू\nयेन्न नीधीये एनिक्याय सन्हमे\nमरक्कान आविल्ला एन्न स्नेहमे\n\nVerse 2\nज्ञानत्तिन जननीये एन्न अम्मयाय\nएनिक्यू नलगी एन्ने ओरुकीडूवान\nदेव भवन‌त्तिल नित्यम झ्वल्लिक्युम\nप्रगाशमे येन्न सर्वमे\nमरक्कान आविल्ला एन्न जीवने\n"
    }
  },
  {
    "sr": "ZS0030",
    "title": "VISHWAASATHIN THONIVIL",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0030",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nविष्वासत्तिन तोणीयिल न्यान \nएगयाय तीरुम्बोळुम\nतीरगळउयरुम न्नेरवुम\nआळम एन्ने मूडम्बाेळुम\n\nCH\nभयप्पेडन्डा कुन्ये\nएन्न आ स्वरम न्यान केटीडुन्नू\nतळरिल्ला न्यान इनी ओरुन्नाळुम\nएन्डे येशू अप्पन कूडे उन्ड \nआ... राधना येशवे \nआ... राधना एन्डे अप्पा\nएन्डे जीवने एन्डे स्वन्दमे\nत्यान एन्नुम अँए आराधिक्युम\n\nVerse 1\nन्यान कूळूत्तादे येन्न च्चूट्टमेरीयुम\nअग्नियाल न्यान तळरुम्बाेळ\nसहायमेगान आरुमिल्लादे\nनीराश्रयनाय न्निन्नीडुम्बोळ\nकरम नीटी चारे अणयुम\nएन्न स्नेहमे एन्न पिदाव\nऑइल्लेगिल न्यान इल्ल येशूवे\nएन्ड जीवन अँए दानम्मल्लो आ... राधना\n\nVerse 2\nआरोरुम अरीयात्त पुन्न अन्दरंगळ\nअरियुम एन्न स्नेहिदन\nकालइडरुमनेरम करंगळिल तांञी येन्ने\nवळी नडत्तुम एन्न पिदाव\nसहनंगळ एन्निल आळुम नेरंगळिल\nअँउ नलगुम सान्द्वम मुदी येनिक्य\nयेन्न जीवनिल वाळुम देवमे\nअँइल मात्रमे येन्न आश्रयम आ.. राधना\n"
    }
  },
  {
    "sr": "ZS0031",
    "title": "ATHYUNNATHAN YESU APPA",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0031",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "Intro\nसर्वोन्नत येशु अप्पा\nसब कुछ मेरे, भलाई में बदलते हैं\nपरिशुद्ध है मेरे अप्पा\nमेरे लिए सब पुनर्स्थापित करते\n\nCH\nआराधना पिता की\nआराधना येशु की\nओ मेरे प्रभु, ओ मेरे पिता\nआप मेरे अभिलाष हो\nओ मेरे स्नेह, ओ जीव श्वास\nहर पल आप, सर्व मेरे\n\nVerse 1\nवेदना में मेरे संकट में भी\nस्वर आपका मुझे आश्वासन देता है\nमार्गदर्शी होकर, नीति के द्वारा\nले चलते मुझे येशु अप्पा\n\nमेरे पापों से, जब मैं गिर जाऊँ\nआपका स्वर मुझे सांत्वना देता\nमेरे सहनों को, मेरी कमियों को\nमेरे भले में, बदलते हैं\n\nVerse 2\nमुझसे कुछ भी उम्मीद ना करे\nमुझे प्यार करते हैं, मेरे अप्पा\nजैसे मुझे आप स्नेह करते\nवैसे मैं आपसे स्नेह करूं\n\nआपके सानिध्य में, मुझे रख लीजिए\nहर पल संभाल दीजिए\nआप में जुड़ जाने, एक हो जाने\nमेरा हृदय वांछित करें\n",
      "Malayalam": "Intro\nअत्यन्नदन येशू अप्पन\nएनिक्येल्लाम नन्मक्याय माटुन्नू\nपरिशुद्धन एन्डे अप्पन \nएनिक्येल्लाम पुनः स्थापिक्युन्नू\n\nCH\nआराधना पिदावे आराधना येशूवे\nयेन्डे दैवमे येन्डे तादने\nअँ आणेन अभीलाषम\nयेन्डे स्नेहमे जीव श्वासमे \nअँ एन्नूम एन्न सर्वम\n\n\nVerse 1\nवेदनयिल येन्नुम् दूूरीदंगळिल\nअँए स्वरम एन्ने आश्वस्सिप्पिक्युन्नू\nवळीकाटीयायेन्न नीधीयीलूडे\nएन्ने नइक्युम येशू अप्पा\nएन्डे पाबंगळाल न्यान तळर्नीडुम्बोळ\nअँए स्वरम, एन्ने तळूगीडुन्नू\nएन्डे सहनंगळे एन्ड कूरवूगळे\nएन्डे नन्मक्याय माटीडुन्नू\n\n\nVerse 2\nएन्निलन्निन्नोन्नुम प्रदीक्षीक्यादे\nएने स्नेहिक्युम एन्डे अप्पा\nअविइन्नन्ने स्नेहिक्युमपोले\nन्यान इन्न अँइल्ल स्नेहिक्यन्नू\nअँए कणमुम्बीलाय एन्न नीरुत्तणमे\nअनूनीमीष्म काकणमे\nअँइल्ल चेर्नीडूवान ओन्नाइडूवान\nएन्डे उळ्ळम वान्जीक्युन्नू\n"
    }
  },
  {
    "sr": "ZS0032",
    "title": "PRAKASHANGALUDE PITHAVE",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
    "page": "0032",
    "style": "",
    "tempo": "",
    "lyrics": {
      "English": "",
      "Hindi": "",
      "Malayalam": "Intro\nअप्पन्निलन्निन्नुम जनिच्चवळ न्यान \nसत्यत्तिन वजन्नताल उरुवायवळ \nन्यानुम ओरू प्रकाशम\nन्यानुम ओरू वेळिच्चम\n\nCH\nप्रगाशंगळ्डे पिदावे\nअनादियिल उळ्ळ प्रगाशेम\nहृदयत्तिन निरविल निन्न एन अधरम\nअँए वाळती पाडीडुन्नू\nआराधिच्चीडुन्नू स्नेहिक्युन्नू अँए\nन्यगळ येशू अप्पा\n\nVerse 1\nआदियिल अम्मा प्रक्षीयेपोल\nकूडोरुक्की अप्पन येनिक्याय\nआइरम आइरम चुम्बनमेगी\nआदि पिदाविल निक्षेबिच्चू\nएन्नोळम मयंञादे एन्नोळम उरंञादे\nएनिक्याय अध्वानिक्यूम येशू अप्पन\n\nVerse 2\nउणंञी वीळर्न्न निलम्मेन्नपोले\nदाहार्तयाय न्यान केण नेरम\nस‌द्वार्त यागुम जीवजलम\nअप्पन एनिक्याय पगर्नू तन्नू\nओरिक्कीलूम पीरीयूगिल्ला\nओरुन्नालूम अगलूगील्ला\nअँए कणमुन्बील निन्नू न्यान मरयूगिल्ला\n"
    }
  },
  {
    "sr": "ZS0033",
    "title": "YESU RAAJAAVODE",
    "Key": "",
    "Dedicated": "APPA",
    "year": "2022.0",
